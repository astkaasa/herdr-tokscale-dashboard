# Copy this file to:
#   $(herdr plugin config-dir tokscale.dashboard)/config.env

# Optional. If unset, the plugin uses `tokscale` from PATH.
# TOKSCALE_CMD="bunx tokscale@latest"
# TOKSCALE_CMD="npx tokscale@latest"
# TOKSCALE_CMD="deno x npm:tokscale@latest"
# TOKSCALE_CMD="/path/to/tokscale"

# Optional. Useful when running Tokscale from a source checkout.
# TOKSCALE_CWD="$HOME/Developer/tokscale"
